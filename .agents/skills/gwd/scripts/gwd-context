#!/usr/bin/env python3
"""Collect transient environment signals for GWD context inference."""

from __future__ import annotations

import argparse
import json
import socket
import sys
from typing import Any, Dict, Optional
from urllib.error import HTTPError, URLError
from urllib.request import Request, urlopen

ENDPOINT = "https://ipwho.is/"
MAX_RESPONSE_BYTES = 128 * 1024


def fetch_network(timeout: float = 4.0) -> Dict[str, Any]:
    request = Request(ENDPOINT, headers={"Accept": "application/json", "User-Agent": "gwd-context/1"})
    try:
        with urlopen(request, timeout=timeout) as response:
            payload = response.read(MAX_RESPONSE_BYTES + 1)
        if len(payload) > MAX_RESPONSE_BYTES:
            raise ValueError("response exceeds size limit")
        data = json.loads(payload.decode("utf-8"))
        if not data.get("success", True):
            raise ValueError(data.get("message") or "provider returned failure")
        security = data.get("security") or {}
        connection = data.get("connection") or {}
        return {
            "status": "available",
            "location": {
                "city": data.get("city"),
                "region": data.get("region"),
                "country": data.get("country"),
                "country_code": data.get("country_code"),
            },
            "network": {
                "organization": connection.get("org"),
                "isp": connection.get("isp"),
                "type": data.get("type"),
            },
            "security": {
                "vpn": security.get("vpn"),
                "proxy": security.get("proxy"),
                "tor": security.get("tor"),
                "relay": security.get("relay"),
            },
            "source": "ipwho.is",
            "confidence": "approximate",
        }
    except (HTTPError, URLError, TimeoutError, ValueError, json.JSONDecodeError) as exc:
        return {"status": "unavailable", "error": str(exc), "confidence": "unknown"}


def collect(include_network: bool = True, timeout: float = 4.0) -> Dict[str, Any]:
    result: Dict[str, Any] = {
        "hostname": {
            "value": socket.gethostname() or None,
            "source": "socket.gethostname",
            "confidence": "high",
        },
        "network": fetch_network(timeout) if include_network else {"status": "skipped", "confidence": "unknown"},
        "privacy": {
            "ip_included": False,
            "persisted": False,
            "note": "Network location describes the internet exit and may differ from physical location.",
        },
    }
    return result


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Collect transient signals for GWD context inference.")
    parser.add_argument("--offline", action="store_true", help="skip external network lookup")
    parser.add_argument("--timeout", type=float, default=4.0)
    return parser


def main(argv: Optional[list[str]] = None) -> int:
    args = build_parser().parse_args(argv)
    json.dump(collect(not args.offline, args.timeout), sys.stdout, ensure_ascii=False, indent=2)
    sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
